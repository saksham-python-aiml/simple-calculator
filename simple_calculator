def calculator():
  a=int(input("Enter a number: "))
  b=int(input("Enter a number: "))
  c=input("Enter the operation sign: ")
  if b==0 and (c=="÷" or c =="/"):
    print("Invalid division by 0")
  elif ("+") in c:
     print(a+b)
  elif ("-") in c:
     print(a-b)
  elif ("×") in c or ("*") in c or ("X") in c or ("x") in c:
     print(a*b)
  elif ("÷") in c or ("/") in c:
     print(a/b)
  else:
    print("Invalid Operation Symbol!")

calculator()
